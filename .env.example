# ─────────────────────────────────────────────────────────────────
# Trading Bot — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# ── Mode ──────────────────────────────────────────────────────────
# DRY_RUN=false enables real order execution.
# Default is true (no real trades).
DRY_RUN=true

# ── Claude API ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Override model if needed (default: claude-opus-4-6)
# CLAUDE_MODEL=claude-opus-4-6

# ── Binance Futures API ───────────────────────────────────────────
# Required only when DRY_RUN=false
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Use Binance testnet instead of mainnet
# BINANCE_TESTNET=true

# ── Risk Management ───────────────────────────────────────────────
# USDT margin per trade (not notional — actual collateral)
MAX_POSITION_MARGIN_USDT=50

# Max USDT loss per position before stop triggers
MAX_LOSS_PER_POSITION_USDT=200

# Daily loss cap: bot pauses new entries after this total loss
DAILY_LOSS_LIMIT_USDT=600

# Simultaneous open positions allowed
MAX_OPEN_POSITIONS=3

# Default leverage (Binance will cap at symbol maximum)
LEVERAGE=20

# ISOLATED or CROSSED
MARGIN_TYPE=ISOLATED

# ── Signal Thresholds ─────────────────────────────────────────────
# Minimum 24h price gain % to appear on gainer radar
MIN_GAINER_PERCENT=5

# OI must rise at least this % over 48h to count as divergence signal
MIN_OI_INCREASE_PERCENT=20

# If price already moved more than this %, disqualify from OI divergence
MAX_PRICE_CHANGE_FOR_OI_SIGNAL=3

# Only consider symbols listed within this many days (new listing filter)
NEW_LISTING_DAYS=180

# ── Binance Square Scraping ───────────────────────────────────────
# Playwright profile dir (reuses the X/Twitter login session)
SQUARE_PROFILE_DIR=.playwright/x-profile

# How many top posts to analyse per scan
SQUARE_TOP_POSTS_LIMIT=30

# ── Scheduling ────────────────────────────────────────────────────
# Cron expression for recurring cycles (default: every 15 minutes)
CRON_SCHEDULE=*/15 * * * *

# ── Logging ───────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
